--- src/daemon/mod.rs
+++ src/daemon/mod.rs
@@ -207,6 +207,12 @@
             }
 
             _ = flush_timer.tick() => {
+                // Check for force flush signal before flushing
+                // We need to get the data directory each time since we're in a loop
+                if let Ok(data_dir) = crate::cli::Config::data_dir() {
+                    let _ = check_force_flush_signal(&data_dir).await;
+                }
+                
                 if !event_queue.is_empty() {
                     do_flush(&mut event_queue, &mut last_flush_status, &mut last_flush_time).await;
                 }
